    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@pi-workflow/application-service": "workspace:*",
    "@pi-workflow/contracts": "workspace:*",
    "@pi-workflow/pi-adapter": "workspace:*",
    "@temporalio/client": "^1.20.2",
    "@temporalio/worker": "^1.20.2",
    "@temporalio/workflow": "^1.20.2"
  },
  "devDependencies": {
    "@pi-workflow/workflow-core": "workspace:*",
    "@types/node": "^24.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
