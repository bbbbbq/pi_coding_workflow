{
  "name": "@pi-workflow/local-runtime",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx src/worker.ts",
    "dev:api": "tsx src/server.ts",
    "dev:orchestrator": "tsx src/orchestrator.ts",
    "build": "tsc -p tsconfig.json --noEmit",
