{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pi Workflow",
  "version": "0.1.0",
  "identifier": "com.caojunze.piworkflow",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Pi Workflow",
        "width": 1320,
        "height": 860,
        "minWidth": 900,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:pi-workflow.db"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../../local-runtime/dist/piwf-runtime.js": "piwf-runtime.js"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
