{
  "name": "@pi-workflow/cli",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "piwf": "./dist/index.js"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node22 --banner:js=\"import { createRequire as __piwfCreateRequire } from 'node:module'; const require = __piwfCreateRequire(import.meta.url);\" --outfile=dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/*.test.ts"
  },
  "dependencies": {
    "@pi-workflow/application-service": "workspace:*",
    "@pi-workflow/contracts": "workspace:*",
    "@pi-workflow/local-runtime": "workspace:*",
    "commander": "^14.0.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
