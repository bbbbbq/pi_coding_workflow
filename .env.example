# Temporal Server and local Orchestrator defaults
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=pi-coding-workflow
PI_WORKFLOW_API_HOST=127.0.0.1
PI_WORKFLOW_API_PORT=8787
# Single Workflow database used by Desktop, CLI, and future MCP clients via the Orchestrator API
# PI_WORKFLOW_DATABASE=/absolute/path/to/piwf.db
# Optional JSON file containing ModelRoutingConfig without credential values
# PI_WORKFLOW_MODEL_ROUTING_FILE=/absolute/path/to/model-routing.json
# Credentials use PI_WORKFLOW_SECRET_<NORMALIZED_SECRET_REF>

# Optional desktop override
VITE_TEMPORAL_API_URL=http://127.0.0.1:8787
